# === AUTHENTICATION (REQUIRED) ===
AUTH_USERNAME=admin
AUTH_PASSWORD=change_me_to_strong_password

# === CORS ===
# JSON array of allowed origins. Use ["*"] for development.
CORS_ORIGINS=["*"]

# === FILE LIMITS ===
MAX_UPLOAD_SIZE_MB=50
MAX_TOTAL_UPLOAD_MB=500
MAX_FILES_PER_UPLOAD=20

# === FILE STORAGE ===
UPLOAD_DIR=/app/data/uploads
PREVIEW_DIR=/app/data/previews
RESULT_DIR=/app/data/results
PRESETS_PATH=/app/data/presets.json

# === TTL & CLEANUP ===
FILE_TTL_HOURS=24
TOKEN_TTL_HOURS=24
CLEANUP_INTERVAL_HOURS=6

# === PROCESSING ===
MAX_CONCURRENT_JOBS=5
PREVIEW_MAX_SIZE=800
JOB_TIMEOUT_SECONDS=600
MAX_IMAGE_PIXELS=25000000
